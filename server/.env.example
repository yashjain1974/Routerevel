# ── Server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────────────
# FREE: Neon https://neon.tech or Railway https://railway.app
DATABASE_URL="postgresql://user:password@localhost:5432/routerevel"

# ── Redis ────────────────────────────────────────────────────────────
# FREE: Upstash https://upstash.com → Create Redis → copy URL
REDIS_URL=''
# ── Google Maps APIs ─────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=''

# ── AI APIs — BOTH FREE ──────────────────────────────────────────────

# PRIMARY: Google Gemini — 1500 req/day free, no credit card
# Get: https://aistudio.google.com → Get API key
GEMINI_API_KEY=''

# FALLBACK: Groq — 30 req/min free, Llama 3.3 70B
# Get: https://console.groq.com → API Keys
GROQ_API_KEY=''

# ── CORS ─────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Cache ────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=86400
